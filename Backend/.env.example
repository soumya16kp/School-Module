DATABASE_URL="postgresql://..."
DIRECT_URL="postgresql://..."
JWT_SECRET="your-secret-key"
PORT=5000
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"

# Optional: Email OTP for school/staff login. If unset, OTP is logged to console (dev only).
# Both options below send to ANY recipient (no domain verification).

# Option 1: Gmail (free) – enable 2FA, then create App Password at Google Account → Security
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-16-char-app-password
# SMTP_FROM=WombTo18 School <your-email@gmail.com>

# Option 2: Brevo (300 emails/day free) – brevo.com → SMTP & API → Create SMTP key
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-registered-email@example.com
# SMTP_PASS=your-smtp-key
# SMTP_FROM=WombTo18 School <your-email@example.com>

# Optional: SMS for parent OTP. If unset, OTP is logged to console (dev only).

# Option 1: Twilio (free trial - twilio.com/try-twilio)
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=+1...

# Option 2: Fast2SMS (India, ₹50 free - fast2sms.com)
# SMS_PROVIDER=fast2sms
# FAST2SMS_API_KEY=your_api_key
# FAST2SMS_SENDER_ID=FSTSMS

# Optional: Disable channels for testing/dummy OTP (values must be "true")
# DISABLE_EMAIL=true
# DISABLE_SMS=true
# DISABLE_WHATSAPP=true

# WhatsApp notifications via Fast2SMS templates (requires pre-approved templates in Fast2SMS)
# FAST2SMS_WHATSAPP_PHONE_NUMBER_ID=579519398574288
# FAST2SMS_WHATSAPP_API_VERSION=v24.0

# OTP template
# FAST2SMS_WHATSAPP_TEMPLATE_OTP_NAME=your_otp_template_name
# FAST2SMS_WHATSAPP_TEMPLATE_OTP_LANGUAGE=en_US

# Access request template (OTP-like variable mapping)
# FAST2SMS_WHATSAPP_TEMPLATE_ACCESS_REQUEST_NAME=your_access_request_template_name
# FAST2SMS_WHATSAPP_TEMPLATE_ACCESS_REQUEST_LANGUAGE=en_US

# Access approved template
# FAST2SMS_WHATSAPP_TEMPLATE_ACCESS_APPROVED_NAME=your_access_approved_template_name
# FAST2SMS_WHATSAPP_TEMPLATE_ACCESS_APPROVED_LANGUAGE=en_US

# Access denied template
# FAST2SMS_WHATSAPP_TEMPLATE_ACCESS_DENIED_NAME=your_access_denied_template_name
# FAST2SMS_WHATSAPP_TEMPLATE_ACCESS_DENIED_LANGUAGE=en_US
