generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              Int        @id @default(autoincrement())
  email           String     @unique
  password        String
  name            String
  schoolId        Int?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  role            UserRole   @default(SCHOOL_ADMIN)
  assignedClass   Int?
  assignedSection String?
  phone           String?
  donations       Donation[]
  eventRequests   EventRequest[] @relation("UserRequests")
  healthEdits    HealthRecordEdit[]
  school          School?    @relation(fields: [schoolId], references: [id])
}

model School {
  id                     Int                   @id @default(autoincrement())
  registrationNo         String                @unique
  schoolName             String
  udiseCode              String?
  schoolType             String
  boardAffiliation       String
  principalName          String
  principalContact       String
  schoolEmail            String                @unique
  studentStrength        Int
  address                String
  state                  String
  city                   String
  pincode                String
  pocName                String?
  pocDesignation         String?
  pocMobile              String?
  pocEmail               String?
  ptaName                String?
  ptaMobile              String?
  ptaDesignation         String?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  academicYear           String?
  channel                String?
  annualCreditGoal       Float?                @default(50000)
  principalImage         String?
  vicePrincipalName      String?
  vicePrincipalContact   String?
  vicePrincipalImage     String?
  nurseCounsellorName    String?
  nurseCounsellorContact String?
  nurseCounsellorImage   String?
  fireDeptName           String?
  fireDeptContact        String?
  fireDeptImage          String?
  policeName             String?
  policeContact          String?
  policeImage            String?
  ndrfName               String?
  ndrfContact            String?
  ndrfImage              String?
  nurseName              String?
  nurseContact           String?
  nurseImage             String?
  gynecologistName       String?
  gynecologistContact    String?
  gynecologistImage      String?
  pediatricianName       String?
  pediatricianContact    String?
  pediatricianImage      String?
  ambassadors            AmbassadorDirectory[]
  certifications         Certification[]
  children               Child[]
  donations              Donation[]
  events                 Event[]
  users                  User[]
  eventRequests          EventRequest[]
}

model Child {
  id             Int                  @id @default(autoincrement())
  registrationNo String               @unique
  name           String
  class          Int
  section        String
  fatherName     String?
  motherName     String?
  fatherNumber   String
  motherNumber   String
  emailId        String?
  mobile         String
  gender         String
  status         String               @default("Pending")
  notes          String?
  schoolId       Int
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  allergicTo     String?
  bloodGroup     String?
  cardToken      String?              @unique
  accessRequests AccessRequest[]
  school         School               @relation(fields: [schoolId], references: [id])
  dataAccessLogs ChildDataAccessLog[]
  healthRecords  HealthRecord[]
}

model ChildDataAccessLog {
  id        Int      @id @default(autoincrement())
  childId   Int
  actorType String
  action    String
  ip        String?
  metadata  Json?
  createdAt DateTime @default(now())
  child     Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
}

model AccessRequest {
  id             Int                 @id @default(autoincrement())
  childId        Int
  requesterName  String
  requesterPhone String
  requesterRole  String
  reason         String
  status         AccessRequestStatus @default(PENDING)
  accessToken    String?             @unique
  expiresAt      DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  child          Child               @relation(fields: [childId], references: [id])
}

model HealthRecord {
  id                   Int       @id @default(autoincrement())
  academicYear         String
  checkupDate          DateTime?
  height               Float?
  weight               Float?
  bmi                  Float?
  dentalOverallHealth  String?
  eyeCheckup           String?
  eyeVisionLeft        String?
  eyeVisionRight       String?
  reportFile           String?
  childId              Int
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  bmiCategory          String?
  bmiPercentile        Float?
  dentalCariesIndex    Float?
  dentalHygieneScore   String?
  dentalNotes          String?
  dentalReferralNeeded Boolean?  @default(false)
  dentalReferralReason String?
  visionNotes          String?
  visionOverall        String?
  visionReferralNeeded Boolean?  @default(false)
  colorBlindness       Boolean?  @default(false)
  eyeSquint            Boolean?  @default(false)
  bmiStatus            String?   @default("Absent")
  eyeStatus            String?   @default("Absent")
  dentalStatus         String?   @default("Absent")
  child                Child     @relation(fields: [childId], references: [id])
  edits                HealthRecordEdit[]
}

model HealthRecordEdit {
  id             Int          @id @default(autoincrement())
  recordId       Int
  userId         Int
  changedAt      DateTime     @default(now())
  changesJson    Json
  record         HealthRecord @relation(fields: [recordId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
}

model Event {
  id             Int                  @id @default(autoincrement())
  schoolId       Int
  type           EventType
  title          String
  description    String?
  academicYear   String
  scheduledAt        DateTime?
  completedAt        DateTime?
  loggingCompletedAt DateTime?
  attendanceJson     Json?
  ambassadorId   Int?
  images         Json?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  goalAmount     Float?               @default(0)
  donations      Donation[]
  ambassador     AmbassadorDirectory? @relation(fields: [ambassadorId], references: [id])
  school         School               @relation(fields: [schoolId], references: [id])
  request        EventRequest?
}

model AmbassadorDirectory {
  id           Int            @id @default(autoincrement())
  type         AmbassadorType
  name         String
  organization String?
  phone        String?
  email        String?
  serviceArea  String?
  active       Boolean        @default(true)
  notes        String?
  schoolId     Int?
  school       School?        @relation(fields: [schoolId], references: [id])
  events       Event[]
}

model EventRequest {
  id             Int           @id @default(autoincrement())
  eventId        Int           @unique
  schoolId       Int
  requesterId    Int
  status         RequestStatus @default(PENDING)
  
  personName     String?
  personContact  String?
  personDetails  String?
  
  officialNotes  String?
  
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  
  event          Event         @relation(fields: [eventId], references: [id])
  school         School        @relation(fields: [schoolId], references: [id])
  requester      User          @relation("UserRequests", fields: [requesterId], references: [id])
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model Certification {
  id           Int                 @id @default(autoincrement())
  schoolId     Int
  type         CertificationType
  status       CertificationStatus
  academicYear String
  issuedAt     DateTime?
  validUntil   DateTime?
  metadata     Json?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  school       School              @relation(fields: [schoolId], references: [id])
}

model OtpCode {
  id        Int      @id @default(autoincrement())
  phone     String?
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  email     String?

  @@index([phone])
  @@index([email])
}

model Donation {
  id          Int      @id @default(autoincrement())
  partnerId   Int
  schoolId    Int
  eventId     Int?
  amount      Float
  type        String
  status      String
  date        DateTime @default(now())
  description String?
  event       Event?   @relation(fields: [eventId], references: [id])
  user        User     @relation(fields: [partnerId], references: [id])
  school      School   @relation(fields: [schoolId], references: [id])
}

model NotificationDispatchLog {
  id        Int      @id @default(autoincrement())
  eventType String
  channel   String
  recipient String
  status    String
  error     String?
  metadata  Json?
  createdAt DateTime @default(now())
}

enum EventType {
  GENERAL_CHECKUP
  DENTAL_SCREENING
  VISION_SCREENING
  BMI_ASSESSMENT
  NUTRITION_SESSION
  HPV_AWARENESS
  EXPERT_SESSION
  FIRE_DRILL
  BLACKOUT_DRILL
  BUNKER_DRILL
  CPR_TRAINING
  FIRST_AID_TRAINING
  CPR_FIRST_AID_TRAINING
  HYGIENE_WELLNESS
  IMMUNIZATION_DEWORMING
  OTHER
  MENTAL_WELLNESS
  IMMUNIZATION
}

enum AmbassadorType {
  FIRE_DEPT
  POLICE
  NDRF
  CPR_TRAINER
  FIRST_AID_TRAINER
  HEALTH_PARTNER
  OTHER
  NURSE
  GYNECOLOGIST
  PEDIATRICIAN
}

enum CertificationType {
  UDISE_COMPLIANCE
  FIRE_SAFETY_DRILL
  ANNUAL_SAFETY
  HEALTH_PROGRAM
  OTHER
}

enum CertificationStatus {
  PENDING
  ACTIVE
  EXPIRED
  REVOKED
}

enum AccessRequestStatus {
  PENDING
  APPROVED
  DENIED
}

enum UserRole {
  SCHOOL_ADMIN
  PRINCIPAL
  CLASS_TEACHER
  NURSE_COUNSELLOR
  DISTRICT_VIEWER
  WOMBTO18_OPS
  PARTNER
  STAFF
}
