generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  schoolId  Int?     @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  role      UserRole @default(SCHOOL_ADMIN)
  school    School?  @relation(fields: [schoolId], references: [id])
  donations Donation[]
}

model School {
  id               Int                   @id @default(autoincrement())
  registrationNo   String                @unique
  schoolName       String
  udiseCode        String?
  schoolType       String
  boardAffiliation String
  principalName    String
  principalContact String
  schoolEmail      String                @unique
  studentStrength  Int
  address          String
  state            String
  city             String
  pincode          String
  pocName          String?
  pocDesignation   String?
  pocMobile        String?
  pocEmail         String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  academicYear     String?
  channel          String?
  ambassadors      AmbassadorDirectory[]
  certifications   Certification[]
  children         Child[]
  events           Event[]
  user             User?
  donations        Donation[]
}

model Child {
  id             Int              @id @default(autoincrement())
  cardToken      String?          @unique // persistent token for QR ID card (OQ-01: token-based, no login)
  registrationNo String           @unique
  name           String
  class          Int
  section        String
  fatherNumber   String
  motherNumber   String
  emailId        String?
  mobile         String
  gender         String
  bloodGroup     String?
  allergicTo     String?
  status         String           @default("Pending")
  notes          String?
  schoolId       Int
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  school         School           @relation(fields: [schoolId], references: [id])
  healthRecords  HealthRecord[]
  accessRequests AccessRequest[]
}

model AccessRequest {
  id             Int                 @id @default(autoincrement())
  childId        Int
  requesterName  String
  requesterPhone String
  requesterRole  String              // e.g. "Doctor", "Nurse", "Teacher"
  reason         String
  status         AccessRequestStatus @default(PENDING)
  accessToken    String?             @unique // set when approved
  expiresAt      DateTime?           // token expiry
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  child          Child               @relation(fields: [childId], references: [id])
}

model HealthRecord {
  id                   Int       @id @default(autoincrement())
  academicYear         String
  checkupDate          DateTime?
  height               Float?
  weight               Float?
  bmi                  Float?
  dentalOverallHealth  String?
  eyeCheckup           String?
  eyeVisionLeft        String?
  eyeVisionRight       String?
  immunization         Boolean   @default(false)
  mentalWellness       Boolean   @default(false)
  nutrition            Boolean   @default(false)
  menstrualHygiene     Boolean   @default(false)
  reportFile           String?
  childId              Int
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  bmiCategory          String?
  bmiPercentile        Float?
  dentalCariesIndex    Float?
  dentalHygieneScore   String?
  dentalNotes          String?
  dentalReferralNeeded Boolean?  @default(false)
  dentalReferralReason String?
  visionNotes          String?
  visionOverall        String?
  visionReferralNeeded Boolean?  @default(false)
  child                Child     @relation(fields: [childId], references: [id])
}

model Event {
  id             Int                  @id @default(autoincrement())
  schoolId       Int
  type           EventType
  title          String
  description    String?
  academicYear   String
  scheduledAt    DateTime?
  completedAt    DateTime?
  attendanceJson Json?
  ambassadorId   Int?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  ambassador     AmbassadorDirectory? @relation(fields: [ambassadorId], references: [id])
  school         School               @relation(fields: [schoolId], references: [id])
  donations      Donation[]
}

model AmbassadorDirectory {
  id           Int            @id @default(autoincrement())
  type         AmbassadorType
  name         String
  organization String?
  phone        String?
  email        String?
  serviceArea  String?
  active       Boolean        @default(true)
  notes        String?
  schoolId     Int?
  school       School?        @relation(fields: [schoolId], references: [id])
  events       Event[]
}

model Certification {
  id           Int                 @id @default(autoincrement())
  schoolId     Int
  type         CertificationType
  status       CertificationStatus
  academicYear String
  issuedAt     DateTime?
  validUntil   DateTime?
  metadata     Json?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  school       School              @relation(fields: [schoolId], references: [id])
}

enum EventType {
  GENERAL_CHECKUP
  DENTAL_SCREENING
  VISION_SCREENING
  BMI_ASSESSMENT
  NUTRITION_SESSION
  HPV_AWARENESS
  EXPERT_SESSION
  FIRE_DRILL
  BLACKOUT_DRILL
  BUNKER_DRILL
  CPR_TRAINING
  FIRST_AID_TRAINING
  OTHER
}

enum AmbassadorType {
  FIRE_DEPT
  POLICE
  NDRF
  CPR_TRAINER
  FIRST_AID_TRAINER
  HEALTH_PARTNER
  OTHER
}

enum CertificationType {
  UDISE_COMPLIANCE
  FIRE_SAFETY_DRILL
  ANNUAL_SAFETY
  HEALTH_PROGRAM
  OTHER
}

enum CertificationStatus {
  PENDING
  ACTIVE
  EXPIRED
  REVOKED
}

enum AccessRequestStatus {
  PENDING
  APPROVED
  DENIED
}

enum UserRole {
  SCHOOL_ADMIN
  PRINCIPAL
  CLASS_TEACHER
  NURSE_COUNSELLOR
  DISTRICT_VIEWER
  WOMBTO18_OPS
  PARTNER
}

model OtpCode {
  id        Int      @id @default(autoincrement())
  phone     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
}

model Donation {
  id          Int      @id @default(autoincrement())
  partnerId   Int
  schoolId    Int
  eventId     Int?
  amount      Float
  type        String   // "EVENT", "CHECKUP", "GENERAL"
  status      String   // "COMPLETED", "PENDING"
  date        DateTime @default(now())
  description String?
  user        User     @relation(fields: [partnerId], references: [id])
  school      School   @relation(fields: [schoolId], references: [id])
  event       Event?   @relation(fields: [eventId], references: [id])
}
